    {
      "cell_type": "markdown",
      "source": [
        "# Data Preprocessing"
      ],
      "metadata": {
        "id": "kEC2FBhjF2J9"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Remove unnecessary column\n",
        "df = df.drop(\"Person ID\", axis=1)\n",
        "\n",
        "# Clean Sleep Disorder column\n",
        "df[\"Sleep Disorder\"] = df[\"Sleep Disorder\"].astype(str)\n",
        "df[\"Sleep Disorder\"] = df[\"Sleep Disorder\"].str.strip()\n",
        "df[\"Sleep Disorder\"] = df[\"Sleep Disorder\"].str.lower()\n",
        "\n",
        "# Convert text to numbers automatically\n",
        "from sklearn.preprocessing import LabelEncoder\n",
        "\n",
        "le = LabelEncoder()\n",
        "df[\"Sleep Disorder\"] = le.fit_transform(df[\"Sleep Disorder\"])\n",
        "\n",
        "# Check if any NaN exists\n",
        "print(\"NaN count:\", df[\"Sleep Disorder\"].isna().sum())"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "tvYHSxqiGC0n",
        "outputId": "02503097-f84d-4ed6-822d-c472e05bcdeb"
      },
      "execution_count": 3,
      "outputs": [
        {
          "output_type": "stream",
