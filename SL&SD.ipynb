            "NaN count: 0\n"
          ]
        }
      ]
    },
    {
      "cell_type": "markdown",
      "source": [
        "# Slpit Features & Labels"
      ],
      "metadata": {
        "id": "wKm6LhMiGJHO"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "X = df.drop([\"Stress Level\", \"Sleep Disorder\"], axis=1)\n",
        "\n",
        "y_stress = df[\"Stress Level\"]\n",
        "y_sleep = df[\"Sleep Disorder\"]"
      ],
      "metadata": {
        "id": "6LOM_fWcGQE1"
      },
      "execution_count": 4,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "# Train Stress Model"
      ],
      "metadata": {
        "id": "cua1WMxPGYf5"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "from sklearn.model_selection import train_test_split\n",
        "from sklearn.ensemble import RandomForestRegressor\n",
        "from sklearn.metrics import mean_absolute_error\n",
        "\n",
        "X_train, X_test, y_train, y_test = train_test_split(X, y_stress, test_size=0.2, random_state=42)\n",
        "\n",
        "model_stress = RandomForestRegressor()\n",
        "model_stress.fit(X_train, y_train)\n",
        "\n",
        "pred = model_stress.predict(X_test)\n",
        "\n",
        "print(\"MAE:\", mean_absolute_error(y_test, pred))"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "dTfsbGsyGdyK",
        "outputId": "35f16138-e07a-4dab-b407-355cadd473c7"
      },
      "execution_count": 5,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "MAE: 1.4510399999999999\n"
          ]
        }
      ]
    },
    {
      "cell_type": "markdown",
      "source": [
        "# Train Sleep Disorder Model"
      ],
      "metadata": {
        "id": "uy-PCdLeG2Ga"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "from sklearn.ensemble import RandomForestClassifier\n",
        "from sklearn.metrics import accuracy_score, classification_report\n",
        "\n",
        "X_train, X_test, y_train, y_test = train_test_split(X, y_sleep, test_size=0.2, random_state=42)\n",
        "\n",
        "model_sleep = RandomForestClassifier()\n",
        "model_sleep.fit(X_train, y_train)\n",
        "\n",
        "pred = model_sleep.predict(X_test)\n",
        "\n",
        "print(\"Accuracy:\", accuracy_score(y_test, pred))\n",
        "print(classification_report(y_test, pred))"
      ],
      "metadata": {
        "colab": {
